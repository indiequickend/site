---
---

<footer class="site-footer">
  <div class="wrap site-footer__row">
    <div class="site-footer__brand">
      <p class="site-footer__name">Prime Peak Stays</p>
      <p class="crest-label">One view, chosen on purpose</p>
    </div>
    <div class="site-footer__meta">
      <p class="geo-tag"><a href="https://wa.me/918910569649" target="_blank" rel="noopener">WhatsApp us</a></p>
      <p class="geo-tag"><a href="tel:+918910569649">+91 89105 69649</a></p>
      <p class="site-footer__copy">&copy; {new Date().getFullYear()} Prime Peak Stays</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dusk-deep);
    color: var(--paper);
    padding-block: var(--space-4);
  }

  .site-footer__row {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .site-footer__name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--paper);
    margin-bottom: 0.35em;
  }

  .site-footer__meta {
    text-align: right;
  }

  .site-footer__meta .geo-tag {
    color: var(--gold-bright);
    justify-content: flex-end;
  }

  .site-footer__copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--mist);
    opacity: 0.7;
    margin-top: 0.5em;
  }

  @media (max-width: 40rem) {
    .site-footer__row {
      flex-direction: column;
      align-items: flex-start;
    }
    .site-footer__meta {
      text-align: left;
    }
    .site-footer__meta .geo-tag {
      justify-content: flex-start;
    }
  }
</style>
